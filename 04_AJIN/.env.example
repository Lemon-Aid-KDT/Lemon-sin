# ═════════════════════════════════════════════════════════════════
# 04_AJIN — 환경변수 템플릿. 이 파일을 .env 로 복사 후 실 값으로 채우세요.
#   cp .env.example .env
#   chmod 600 .env
#
# .env 는 .gitignore 에 의해 절대 commit 되지 않습니다.
# ═════════════════════════════════════════════════════════════════

# ───── Ollama (자가 호스팅 LLM) ─────
# 로컬 dev 시 localhost, 운영 시 Cloud Run 가 watchdog 으로 자동 갱신.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_TIMEOUT=60
OLLAMA_KEEP_ALIVE=24h

# 모델 매핑 (라우터 chain)
OLLAMA_MODEL_CHAT_LARGE=qwen3.5:9b
OLLAMA_MODEL_CHAT_SMALL=qwen3.5:4b
OLLAMA_MODEL_GEMMA_LARGE=gemma4:e4b
OLLAMA_MODEL_GEMMA_SMALL=gemma4:e2b
OLLAMA_MODEL_EMBEDDING=bge-m3

# ───── LLM Router 정책 ─────
# Plan A 변형: ollama 우선 → fallback gemini
LLM_ROUTER_PRIMARY=ollama
LLM_ROUTER_FALLBACK_ENABLED=false
LLM_ROUTER_CIRCUIT_BREAKER_THRESHOLD=3
LLM_ROUTER_CIRCUIT_RECOVERY_SEC=60

# ───── Caddy reverse proxy 인증 (운영) ─────
# 로컬 dev (직접 :11434 호출) 에서는 빈값 OK.
# 운영: 32-byte hex (openssl rand -hex 32)
AJIN_OLLAMA_SECRET=

# ───── Embedding backend (auto: OLLAMA_BASE_URL 비어있으면 gemini) ─────
EMBEDDING_BACKEND=auto

# ───── Gemini API (Module B/C 폴백, 임베딩) ─────
# https://aistudio.google.com 에서 발급
GEMINI_API_KEY=

# ───── 인증 ─────
# JWT 서명 키 (32-byte hex 권장)
AJIN_JWT_SECRET=
AUTH_BACKEND=sqlite          # sqlite | firestore

# ───── Feature flags ─────
ENABLE_FEATURE_A=true        # 검색
ENABLE_FEATURE_B=true        # 문서 작성
ENABLE_FEATURE_E=true        # HR 통계
FEATURE_B_BLOCK_GEMINI=false
FEATURE_C_INLINE_ACTIONS=true
FEATURE_C_MULTI_LLM=true
FEATURE_C_QUICK_QUESTIONS_V2=true
FEATURE_C_DEPT_LOCK=true
FEATURE_C_DIVISION_BOUNDARY=true
FEATURE_C_WORK_FULLSCREEN=true
FEATURE_C_CAD_UPLOAD=true
FEATURE_C_COMPARE_MODE=true

# ───── CORS ─────
CORS_ORIGINS=http://localhost:5173,https://ajin-cb.web.app

# ───── Meilisearch (G1 — 법규 전문검색) ─────
MEILI_HOST=http://localhost:7700
MEILI_MASTER_KEY_FILE=secrets/meili_master_key

# ───── Celery / Redis (G3 — 배경 작업) ─────
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ───── SMTP (G2 — 알림 메일) ─────
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USE_TLS=false
SMTP_USERNAME=
SMTP_PASSWORD_FILE=secrets/smtp_password
SMTP_FROM=ajin-compliance@example.com
SMTP_REPLY_TO=compliance-team@example.com

# ───── Frontend (Vite) ─────
# VITE_* 변수는 frontend/.env 또는 frontend/.env.local 에 별도 정의.
# (build 시 빌드 산출물에 inline — 시크릿 절대 X)
