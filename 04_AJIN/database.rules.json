{
  "rules": {
    "live_alarms": {
      ".read": "auth != null",
      ".write": "auth != null && auth.token.role_level >= 3",
      "$alarm_id": {
        ".validate": "newData.hasChildren(['severity', 'title', 'detail', 'module', 'timestamp'])"
      }
    },
    "audit_log": {
      ".read": "auth != null && auth.token.role_level >= 5",
      ".write": false,
      "$entry_id": {
        ".validate": false
      }
    },
    "login_history": {
      "$user_id": {
        ".read": "auth != null && (auth.uid == $user_id || auth.token.role_level >= 5)",
        ".write": false
      }
    },
    "feedback": {
      ".read": "auth != null && auth.token.role_level >= 4",
      "$message_id": {
        ".write": "auth != null"
      }
    },
    "presence": {
      ".read": "auth != null",
      "$user_id": {
        ".write": "auth != null && auth.uid == $user_id"
      }
    },
    "notifications": {
      "$user_id": {
        ".read": "auth != null && auth.uid == $user_id",
        ".write": "auth != null && auth.token.role_level >= 3"
      }
    },
    "spc_realtime": {
      ".read": "auth != null",
      ".write": false
    }
  }
}
