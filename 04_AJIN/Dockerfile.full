# DEPRECATED — v3.6.1 부터 단일 Dockerfile (multi-stage) 로 통합됨.
#
# 풀 모드 빌드:
#   docker build --target full -t ajin-backend:full .
#
# Cloud Build / gcloud:
#   bash scripts/deploy-backend.sh --mode full
#   # 또는
#   gcloud builds submit --config cloudbuild.yaml --substitutions=_MODE=full
#
# 본 파일은 BC (역호환) 차원에서 남아있고 내용은 unified Dockerfile 의 full target 으로 forward.
# 직접 사용 금지 — 사고 빈도가 높았던 두 Dockerfile 분리 구조의 잔재.

FROM ajin-backend:full
