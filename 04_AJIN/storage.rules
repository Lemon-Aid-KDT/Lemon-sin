rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // 공개 자산 (로고, 매뉴얼) — 인증된 사용자만 read
    match /pdfs/manuals/{file} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.token.role_level >= 4;
    }
    match /pdfs/regulations/{file} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.token.role_level >= 5;
    }
    match /templates/{file=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.token.role_level >= 4;
    }
    match /ml_models/{file=**} {
      allow read: if request.auth != null && request.auth.token.role_level >= 5;
      allow write: if request.auth != null && request.auth.token.role_level >= 6;
    }

    // 사용자별 파일 (본인만 read/write, 10MB 제한)
    match /images/{userId}/{file} {
      allow read, write: if request.auth != null
        && request.auth.uid == userId
        && request.resource.size < 10 * 1024 * 1024;
    }
    match /uploads/{userId}/{file} {
      allow read, write: if request.auth != null
        && request.auth.uid == userId
        && request.resource.size < 20 * 1024 * 1024;
    }
  }
}
