rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 공개 컬렉션 (인증된 사용자만 read, write 차단)
    match /employees/{empId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.token.role_level >= 4;
    }
    match /departments/{deptId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.token.role_level >= 5;
    }
    match /plants/{plantId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.token.role_level >= 5;
    }
    match /error_codes/{code} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.token.role_level >= 4;
    }
    match /molds/{moldId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.token.role_level >= 4;
    }
    match /scenarios/{scenarioId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.token.role_level >= 5;
    }
    match /glossary/{term} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.token.role_level >= 4;
    }
    match /sop_guides/{sopId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.token.role_level >= 4;
    }

    // 사용자별 컬렉션 (본인만 read/write)
    match /chat_history/{userId}/{messageId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    match /documents/{userId}/{docId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // 인사 관리 (HR_ADMIN 이상만)
    match /accounts/{accountId} {
      allow read, write: if request.auth != null && request.auth.token.role_level >= 5;
    }

    // 통계 / 집계 (TEAM_LEAD 이상)
    match /stats/{statId} {
      allow read: if request.auth != null && request.auth.token.role_level >= 4;
      allow write: if false; // 백엔드만 작성
    }

    // 인증 백엔드 (서버 SDK 전용 — 클라이언트 접근 완전 차단)
    // password_hash 보호. firebase-admin SDK 는 rules 우회.
    match /auth_users/{employeeId} {
      allow read, write: if false;
    }
    match /auth_roles/{roleName} {
      allow read, write: if false;
    }
  }
}
