<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>Label</key>
	<string>com.ajin.tunnel-watchdog</string>
	<key>ProgramArguments</key>
	<array>
		<string>/bin/bash</string>
		<string>__USER_HOME__/.config/ajin/tunnel-watchdog.sh</string>
	</array>
	<key>RunAtLoad</key>
	<true/>
	<key>KeepAlive</key>
	<dict>
		<key>SuccessfulExit</key>
		<false/>
	</dict>
	<key>ThrottleInterval</key>
	<integer>30</integer>
	<key>StandardOutPath</key>
	<string>__USER_HOME__/.config/ajin/watchdog.stdout.log</string>
	<key>StandardErrorPath</key>
	<string>__USER_HOME__/.config/ajin/watchdog.stderr.log</string>
	<key>ProcessType</key>
	<string>Background</string>
</dict>
</plist>
