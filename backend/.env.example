# Environment
ENVIRONMENT=development
LOG_LEVEL=DEBUG

# Database (Phase 1 후반부터 사용)
DATABASE_URL=postgresql+asyncpg://lemon:lemon@localhost:5432/lemon
REDIS_URL=redis://localhost:6379/0

# HTTP Security
# Pydantic Settings reads list values from JSON strings.
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:5173","http://localhost:52100","http://127.0.0.1:52100"]
ALLOWED_HOSTS=["localhost","127.0.0.1","testserver"]

# Auth (production user app must use OAuth/OIDC JWT verification)
AUTH_MODE=disabled
JWT_ISSUER=
JWT_AUDIENCE=
JWT_JWKS_URL=
JWT_ALGORITHMS=["RS256"]
JWT_LEEWAY_SECONDS=60
JWT_REQUIRED_CLAIMS=["exp","iss","sub","aud","iat"]
JWT_SCOPE_CLAIMS=["scope","scp"]
# Prefer at+jwt for RFC 9068 access tokens. Use JWT_TOKEN_USE_* when a provider only emits typ=JWT.
JWT_EXPECTED_TOKEN_TYPE=
JWT_TOKEN_USE_CLAIM=
JWT_TOKEN_USE_ALLOWED_VALUES=[]
JWT_JWKS_CACHE_TTL_SECONDS=300
JWT_JWKS_TIMEOUT_SECONDS=5
OIDC_DISCOVERY_URL=
PRIVACY_HASH_SECRET=development-insecure-privacy-hash-secret

# LLM (Phase 2부터 사용)
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen3.5:9b
OLLAMA_VISION_MODEL=gemma4:e4b
OLLAMA_TIMEOUT_SEC=60
OLLAMA_TEMPERATURE=0
SGLANG_BASE_URL=http://127.0.0.1:30000/v1
SGLANG_MODEL=qwen3.5:9b
SGLANG_API_KEY=
ALLOW_EXTERNAL_LLM=false

# External APIs (Phase 2부터 사용)
# Google Vision OCR is fail-closed by default. Local smoke tests may set
# GOOGLE_VISION_AUTH_MODE=api_key with GOOGLE_CLOUD_API_KEY. Production must use
# GOOGLE_VISION_AUTH_MODE=adc with an attached OCR service account.
OCR_PRIMARY_PROVIDER=none
ALLOW_EXTERNAL_OCR=false
GOOGLE_VISION_AUTH_MODE=api_key
GOOGLE_CLOUD_API_KEY=
GOOGLE_CLOUD_PROJECT=
GOOGLE_VISION_LOCATION=global
GOOGLE_VISION_FEATURE=document_text_detection
GOOGLE_VISION_LANGUAGE_HINTS=[]
GOOGLE_VISION_TIMEOUT_SECONDS=15
GOOGLE_VISION_MAX_RETRIES=2
CLOVA_OCR_API_URL=
CLOVA_OCR_SECRET=
DATA_GO_KR_SERVICE_KEY=
MFDS_API_KEY=
MFDS_DATA_API_KEY=
KDCA_HEALTHINFO_API_KEY=
NCBI_API_KEY=
NCBI_TOOL_NAME=lemon-aid
NCBI_EMAIL=
SEMANTIC_SCHOLAR_API_KEY=
OPENFDA_API_KEY=
CROSSREF_MAILTO=
GOOGLE_CSE_API_KEY=
GOOGLE_CSE_ID=

# Supplement OCR image intake
SUPPLEMENT_IMAGE_MAX_BYTES=5242880
SUPPLEMENT_IMAGE_MAX_PIXELS=12000000
SUPPLEMENT_PREVIEW_TTL_MINUTES=30
SUPPLEMENT_OCR_TEXT_MAX_CHARS=12000
SUPPLEMENT_PARSER_ALGORITHM_VERSION=supplement-ollama-parser-v1.0.0
SUPPLEMENT_PARSER_MAX_INGREDIENTS=80
REGULATED_DOCUMENT_PREVIEW_TTL_MINUTES=30
SENSITIVE_DOCUMENT_ORIGINAL_IMAGE_RETENTION_SECONDS=0

# KDRIs data
# Development keeps the non-production 2020 sample fixture.
# Production must keep KDRIS_DATA_VERSION=2025,
# KDRIS_DATA_PATH=data/nutrition_reference/kdris/kdris_2025.csv,
# and ALLOW_SAMPLE_KDRIS=false after official 2025 rows pass review/validation.
KDRIS_DATA_VERSION=2025
KDRIS_DATA_PATH=data/nutrition_reference/kdris/kdris_2025.csv
KDRIS_MANIFEST_PATH=data/nutrition_reference/kdris/kdris_source_manifest.json
ALLOW_SAMPLE_KDRIS=false

# Regulated feature flags
FEATURE_PRESCRIPTION_OCR_INTAKE=false
FEATURE_LAB_RESULT_OCR_INTAKE=false
FEATURE_DOSAGE_CHANGE_RECOMMENDATION=false
FEATURE_MEDICATION_SAFETY_ALERT=false

# ---------------------------------------------------------------------------
# Phase 게이트 플래그 — docs/17-image-collection-consent-plan.md §9 매핑.
# 모든 기본값 false / 0. 운영 환경에서 true 로 변경하려면 발주처 리뷰 게이트
# (#1/#2/#3) 통과 후에만 가능. config.py 의 production validator 가 game-on
# 상태를 차단한다.
# ---------------------------------------------------------------------------
# Phase 2 / 게이트 #1: Ollama 멀티모달 보조 채널 (Gemma 4 등)
ENABLE_MULTIMODAL_LLM=false
MULTIMODAL_OCR_ASSIST_POLICY=disabled
ENABLE_MULTIMODAL_VERIFICATION=false
MULTIMODAL_VERIFICATION_SAMPLE_RATE=0
MULTIMODAL_VERIFICATION_THRESHOLD=0.80
# Phase 3 / 게이트 #2: YOLO 영양제 라벨 영역 검출
ENABLE_VISION_CLASSIFIER=false
VISION_CLASSIFIER_MODEL=yolov8n.pt
OCR_ROI_PREPROCESSING_POLICY=disabled
VISION_ROI_MIN_CONFIDENCE=0.50
VISION_ROI_ALLOWED_CLASSES=["supplement_label","supplement_bottle","blister_pack"]
# Optional OCR fallbacks remain disabled until fixture reports and sign-off pass.
ENABLE_LOCAL_OCR=false
LOCAL_OCR_PROVIDER=paddleocr
LOCAL_OCR_LANGUAGE=korean
LOCAL_OCR_DEVICE=
LOCAL_OCR_CONFIDENCE_THRESHOLD=0.75
ENABLE_CLOVA_OCR=false
# Phase 4 / 게이트 #3: 학습 적재 파이프라인 + pgvector
ENABLE_IMAGE_LEARNING_PIPELINE=false
ENABLE_PGVECTOR_STORAGE=false
EMBEDDING_MODEL=clip-ViT-B-32
# 실제 모델 probe로 차원이 확인된 뒤에만 설정한다. 비워두면 runner 결과를 기록한다.
EMBEDDING_DIMENSIONS=
# 이미지 보유 기간(일). 0 = 분석 직후 즉시 삭제 (docs/17 §5).
IMAGE_RETENTION_DAYS=0
LEARNING_OBJECT_STORAGE_PROVIDER=disabled
LEARNING_OBJECT_STORAGE_BUCKET=
LEARNING_OBJECT_STORAGE_PREFIX=learning/images
LEARNING_OBJECT_STORAGE_ENDPOINT_URL=
LEARNING_OBJECT_STORAGE_REGION=
LEARNING_OBJECT_STORAGE_SSE=AES256
LEARNING_OBJECT_STORAGE_LOCAL_PATH=.local/learning-images
