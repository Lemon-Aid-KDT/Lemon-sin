# Environment
ENVIRONMENT=development
# local/private/public. public staging is validated like a release gate.
DEPLOYMENT_EXPOSURE=local
LOG_LEVEL=DEBUG

# Database (Phase 1 후반부터 사용)
DATABASE_URL=postgresql+asyncpg://lemon:lemon@localhost:5432/lemon  # pragma: allowlist secret
REDIS_URL=redis://localhost:6379/0

# Supabase hosted project / MCP / migration inputs.
# 실제 값은 로컬 .env 또는 비밀 저장소에만 입력하고 커밋하지 않는다.
SUPABASE_PROJECT_REF=
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
# Backend-only. 브라우저, Flutter, frontend bundle, PR 본문에 넣지 않는다.
SUPABASE_SECRET_KEY=
# Headless/CI MCP 인증에만 사용한다. 일반 local MCP는 OAuth 인증을 우선 사용한다.
SUPABASE_ACCESS_TOKEN=
# Supabase Postgres direct URL. 원격 migration/preflight 전용이며 로그에 출력하지 않는다.
SUPABASE_DB_URL=
SUPABASE_MCP_READ_ONLY=true
SUPABASE_MCP_FEATURES=database,docs,debugging,storage
SUPABASE_STORAGE_PRIVATE_BUCKET=learning-images
# Server-only Supabase Storage S3 credentials from project Storage S3 settings.
# These bypass Storage RLS and must stay backend/secret-manager only.
SUPABASE_STORAGE_S3_ACCESS_KEY_ID=
SUPABASE_STORAGE_S3_SECRET_ACCESS_KEY=

# HTTP Security
# Pydantic Settings reads list values from JSON strings.
# For ngrok mobile tests, add the frontend ngrok origin and backend ngrok host.
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:5173"]
ALLOWED_HOSTS=["localhost","127.0.0.1","testserver"]
RATE_LIMIT_ENABLED=false
RATE_LIMIT_DEFAULT_PER_MINUTE=60
RATE_LIMIT_IMAGE_UPLOAD_PER_MINUTE=5
RATE_LIMIT_LLM_EXPLAIN_PER_MINUTE=10

# Auth (production user app must use OAuth/OIDC JWT verification)
AUTH_MODE=disabled
JWT_ISSUER=
JWT_AUDIENCE=
JWT_JWKS_URL=
JWT_ALGORITHMS=["RS256"]
JWT_LEEWAY_SECONDS=60
JWT_REQUIRED_CLAIMS=["exp","iss","sub","aud","iat"]
JWT_SCOPE_CLAIMS=["scope","scp"]
# Prefer at+jwt for RFC 9068 access tokens. Use JWT_TOKEN_USE_* when a provider only emits typ=JWT.
JWT_EXPECTED_TOKEN_TYPE=
JWT_TOKEN_USE_CLAIM=
JWT_TOKEN_USE_ALLOWED_VALUES=[]
JWT_JWKS_CACHE_TTL_SECONDS=300
JWT_JWKS_TIMEOUT_SECONDS=5
# --- Supabase Auth 프로파일 (ADR 39) — Supabase 프로젝트로 위 JWT_* 채우기 ---
# 전제: Supabase 프로젝트가 비대칭 JWT 서명 키(RS256/ES256)를 쓰도록 설정돼야 한다. Supabase
# 기본은 HS256(대칭)이며 이 백엔드는 production에서 대칭을 거부한다 → Dashboard의 JWT signing
# keys를 비대칭으로 전환 필수. 값 형식의 권위 출처는 src/security/supabase_auth.py.
# 공식: https://supabase.com/docs/guides/auth/jwts  ( <ref> = SUPABASE_PROJECT_REF )
#   AUTH_MODE=jwt
#   JWT_ISSUER=https://<ref>.supabase.co/auth/v1
#   JWT_AUDIENCE=authenticated
#   JWT_JWKS_URL=https://<ref>.supabase.co/auth/v1/.well-known/jwks.json
#   JWT_ALGORITHMS=["RS256","ES256"]
#   JWT_EXPECTED_TOKEN_TYPE=JWT
OIDC_DISCOVERY_URL=
PRIVACY_HASH_SECRET=development-insecure-privacy-hash-secret

# LLM (Phase 2부터 사용)
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://127.0.0.1:11434
# Optional: set this in the shell before `ollama serve` when models are on an external volume.
# OLLAMA_MODELS=/Volumes/Corsair EX400U Media/.ollama/models
# For default text parsing and local explanation: gemma4:e4b.
OLLAMA_MODEL=gemma4:e4b
# For multimodal assist and OCR verification: gemma4:e4b.
OLLAMA_VISION_MODEL=gemma4:e4b
OLLAMA_TIMEOUT_SEC=60
OLLAMA_TEMPERATURE=0
ALLOW_EXTERNAL_LLM=false
LLM_WIKI_RETRIEVAL_ENABLED=true
LLM_WIKI_PATH=/Volumes/Corsair EX400U Media/LLM-WIKI
LLM_WIKI_MAX_SOURCES=4
LLM_WIKI_EXCERPT_CHARS=700

# External APIs (Phase 2부터 사용)
# OCR provider — CURRENT PHASE is CLOVA-only while PaddleOCR is being retrained:
# CLOVA primary + local OCR off + external OCR allowed (CLOVA sends label images to
# NAVER Cloud, so ALLOW_EXTERNAL_OCR=true is a required, explicit consent opt-in).
# NOTE: the config.py code default stays paddleocr/local-first (privacy-conservative);
# this template reflects the deployed phase. Revert to OCR_PRIMARY_PROVIDER=paddleocr +
# ENABLE_LOCAL_OCR=true once PaddleOCR retraining lands. Google Vision remains an explicit
# live-smoke/comparison opt-in and production must use ADC when enabled.
OCR_PRIMARY_PROVIDER=clova
ENABLE_LOCAL_OCR=false
ENABLE_CLOVA_OCR=true
ALLOW_EXTERNAL_OCR=true
GOOGLE_VISION_AUTH_MODE=api_key
GOOGLE_CLOUD_API_KEY=
GOOGLE_CLOUD_PROJECT=
GOOGLE_VISION_LOCATION=global
GOOGLE_VISION_FEATURE=document_text_detection
GOOGLE_VISION_LANGUAGE_HINTS=[]
GOOGLE_VISION_TIMEOUT_SECONDS=15
GOOGLE_VISION_MAX_RETRIES=2
OCR_CONFIDENCE_THRESHOLD=0.85
# Explicit live OCR operator switches. Keep false/0 unless running local smoke or
# baseline seed collection from a consented manifest.
RUN_GOOGLE_VISION_SMOKE=0
RUN_PADDLEOCR_PROBE=0
RUN_CLOVA_OCR_LIVE_SMOKE=0
# CLOVA_OCR_API_URL is the NAVER Cloud CLOVA OCR API Gateway Invoke URL.
# It is not a Firebase, GitHub Pages, purchased DNS, or mobile app URL.
CLOVA_OCR_API_URL=
# CLOVA_OCR_SECRET is the X-OCR-SECRET value from the CLOVA OCR Domain/API Gateway setup.
# Keep it backend-only; never place it in Flutter or frontend bundles.
# Do not use the NCP account Access Key/Secret Key here unless a separate Ncloud
# management API integration is added.
CLOVA_OCR_SECRET=
CLOVA_OCR_TIMEOUT_SECONDS=15
CLOVA_OCR_MAX_RETRIES=1

# Label Studio (YOLO section bbox annotation review)
# LABEL_STUDIO_API_TOKEN is a Label Studio Personal Access Token
# (Account & Settings > Personal Access Token). Backend-only; never commit it or
# place it in Flutter/frontend bundles. Used to pull reviewed YOLO section
# annotations via the Label Studio API. Leave blank to use the manual JSON
# file-export path instead.
LABEL_STUDIO_URL=http://localhost:8080
LABEL_STUDIO_API_TOKEN=

# Official barcode/product identity lookup (P1-1)
ENABLE_BARCODE_LOOKUP=false
# 식품안전나라 데이터활용서비스 인증키. C003/I0760 같은 MFDS OpenAPI 조회에 사용.
MFDS_API_KEY=
# 공공데이터포털 FoodQR 정보 서비스 인증키. 일반 EAN/UPC/GTIN brcd_no 조회에 사용.
FOODQR_SERVICE_KEY=
FOODQR_BASE_URL=https://apis.data.go.kr/1471000/FoodQrInfoService01
FOODQR_PRODUCT_LIST_PATH=/getFoodQrProdList01
# Optional: set only after the official Swagger/detail path is confirmed.
FOODQR_PRODUCT_MANUFACTURING_PATH=
FOODQR_TIMEOUT_SECONDS=10
FOODQR_MAX_RETRIES=2
FOODQR_NUM_OF_ROWS=10
MFDS_OPENAPI_BASE_URL=http://openapi.foodsafetykorea.go.kr/api
MFDS_OPENAPI_TIMEOUT_SECONDS=10
MFDS_OPENAPI_MAX_RETRIES=2
MFDS_OPENAPI_PAGE_SIZE=100

# Supplement OCR image intake
SUPPLEMENT_IMAGE_MAX_BYTES=5242880
SUPPLEMENT_IMAGE_MAX_PIXELS=12000000
SUPPLEMENT_PREVIEW_TTL_MINUTES=30
SUPPLEMENT_OCR_TEXT_MAX_CHARS=12000
# OCR 원문 저장 운영자 opt-in (기본 false). true 면 정규화된 OCR 원문 전체를 owner-scoped
# 분석 미리보기 snapshot(top-level raw_ocr_text)에 임시 보관해 "OCR 텍스트 전체" 모달에서
# 원문을 보여준다. 단, 사용자별 RAW_OCR_TEXT_RETENTION 동의가 함께 있어야 실제 저장된다
# (둘 다 없으면 어떤 경로에서도 저장하지 않음 — 동의 약속 유지).
STORE_RAW_OCR_TEXT=false
SUPPLEMENT_PARSER_ALGORITHM_VERSION=supplement-ollama-parser-v1.0.0
SUPPLEMENT_PARSER_MAX_INGREDIENTS=80
REGULATED_DOCUMENT_PREVIEW_TTL_MINUTES=30
SENSITIVE_DOCUMENT_ORIGINAL_IMAGE_RETENTION_SECONDS=0

# KDRIs data
# Development keeps the non-production 2020 sample fixture.
# Production must keep KDRIS_DATA_VERSION=2025,
# KDRIS_DATA_PATH=data/nutrition_reference/kdris/kdris_2025.csv,
# and ALLOW_SAMPLE_KDRIS=false after official 2025 rows pass review/validation.
KDRIS_DATA_VERSION=2025
KDRIS_DATA_PATH=data/nutrition_reference/kdris/kdris_2025.csv
KDRIS_MANIFEST_PATH=data/nutrition_reference/kdris/kdris_source_manifest.json
ALLOW_SAMPLE_KDRIS=false

# Regulated feature flags
FEATURE_PRESCRIPTION_OCR_INTAKE=false
FEATURE_LAB_RESULT_OCR_INTAKE=false
FEATURE_DOSAGE_CHANGE_RECOMMENDATION=false
FEATURE_MEDICATION_SAFETY_ALERT=false

# ---------------------------------------------------------------------------
# Phase 게이트 플래그 — docs/17-image-collection-consent-plan.md §9 매핑.
# 모든 기본값 false / 0. 운영 환경에서 true 로 변경하려면 발주처 리뷰 게이트
# (#1/#2/#3) 통과 후에만 가능. config.py 의 production validator 가 game-on
# 상태를 차단한다.
# ---------------------------------------------------------------------------
# Phase 2 / 게이트 #1: Ollama 멀티모달 보조 채널 (Gemma 4 등)
ENABLE_MULTIMODAL_LLM=false
MULTIMODAL_OCR_ASSIST_POLICY=disabled
ENABLE_MULTIMODAL_VERIFICATION=false
MULTIMODAL_VERIFICATION_SAMPLE_RATE=0
MULTIMODAL_VERIFICATION_THRESHOLD=0.80
# 선택적 vision 추론 단계(multimodal 보조·검증)의 단계당 시간 예산(초). 초과 시 해당
# 단계를 건너뛰고 primary 결과로 진행 → 동기 분석 응답이 모바일 60s 업로드 타임아웃을
# 넘지 않게 막는다. 단계당이라 활성 단계 수만큼 합산(현재 최대 2). 1~20, GPU에서만 상향.
ANALYZE_OPTIONAL_STAGE_BUDGET_SEC=15
# Phase 3 / 게이트 #2: YOLO 영양제 라벨 영역(SECTION) 검출
ENABLE_VISION_CLASSIFIER=false
# 8-class 영양제 SECTION 검출기 슬롯. 기본 yolo26n.pt는 stock COCO 모델이라 로드 시
# _validate_model_class_contract에서 거부된다 → 운영 시 학습된 section 가중치 경로로 교체.
VISION_CLASSIFIER_MODEL=yolo26n.pt
OCR_ROI_PREPROCESSING_POLICY=disabled
VISION_ROI_MIN_CONFIDENCE=0.50
VISION_ROI_MAX_DETECTIONS=16
VISION_ROI_ALLOWED_CLASSES=["product_identity","supplement_facts","ingredient_amounts","precautions","allergen_warning","intake_method","other_ingredients","functional_claims","supplement_label","supplement_bottle","blister_pack"]

# Food image local YOLO detector. Local model files stay ignored by git.
ENABLE_FOOD_YOLO_DETECTOR=false
MEAL_YOLO_MODEL_PATH=/app/Food-backend/best.pt
MEAL_YOLO_MODEL_LABEL=food_yolo_local
MEAL_YOLO_MIN_CONFIDENCE=0.25
MEAL_YOLO_MAX_DETECTIONS=20

# Food image DINOv3 classifier. Requires INSTALL_VISION=true Docker build,
# exp16b gate weights at Food-backend/best.pt, probe_head.pt in Food-backend,
# and HF_TOKEN after accepting the gated Hugging Face model license.
ENABLE_FOOD_DINO_CLASSIFIER=false
MEAL_FOOD_CLASSIFIER_MODULE_DIR=/app/Food-backend/src/classifier
MEAL_FOOD_CLASSIFIER_EXP16B_MODEL_PATH=/app/Food-backend/best.pt
MEAL_FOOD_CLASSIFIER_PROBE_PATH=/app/Food-backend/src/classifier/probe_head.pt
MEAL_FOOD_CLASSIFIER_NUTRITION_CSV_PATH=/app/Food-backend/src/classifier/nutrition/food_nutrition_40class.csv
MEAL_FOOD_CLASSIFIER_MODEL_LABEL=food_dino_exp16b
# Handoff module experiment values, not official recommended values.
MEAL_FOOD_CLASSIFIER_GATE_CONFIDENCE=0.10
MEAL_FOOD_CLASSIFIER_MAX_PX=896
# CLIP non-food filter (off by default): cuts YOLO false positives (people, empty
# dishes, sauce/paper cups) between the YOLO gate and DINOv3 classify. When enabled it
# adds a per-request CLIP (CPU) pass + a one-time ~600MB model load on the synchronous
# path (mobile-timeout sensitive) — measure latency before enabling.
ENABLE_FOOD_CLIP_FILTER=false
FOOD_CLIP_FILTER_THRESHOLD=0.5
FOOD_CLIP_FILTER_MODEL_ID=openai/clip-vit-base-patch16
# Hugging Face Hub read token for gated DINOv3 food classifier models.
# Use the official huggingface_hub variable name. Keep backend-only.
HF_TOKEN=

# PaddleOCR local OCR is the primary supplement-label OCR path by default.
ENABLE_LOCAL_OCR=true
LOCAL_OCR_PROVIDER=paddleocr
LOCAL_OCR_LANGUAGE=korean
LOCAL_OCR_DEVICE=
LOCAL_OCR_ENGINE=paddle
LOCAL_OCR_USE_DOC_ORIENTATION_CLASSIFY=false
LOCAL_OCR_USE_DOC_UNWARPING=false
LOCAL_OCR_USE_TEXTLINE_ORIENTATION=false
LOCAL_OCR_PADDLEX_CONFIG=
LOCAL_OCR_TEXT_RECOGNITION_MODEL_DIR=
LOCAL_OCR_TEXT_DETECTION_MODEL_DIR=
LOCAL_OCR_TEXT_RECOGNITION_MODEL_NAME=
LOCAL_OCR_TEXT_DETECTION_MODEL_NAME=
LOCAL_OCR_CONFIDENCE_THRESHOLD=0.75
# PaddleOCR DB 검출 임계(무학습 튜너블). 빈 값=PaddleOCR 공식 기본(thresh 0.3 / box 0.6
# / unclip 2.0; 공식 URL은 src/config.py 필드 주석 참조). 2026-06-13 b32 홀드아웃 스윕:
# box_thresh=0.4 단독이 최선(within-sweep macro +0.0098 / micro +0.0175 / ingredient_recall
# +0.021). thresh 0.2·unclip 2.5는 소폭 +이나 3종 동시 적용은 precision 하락(오버슈트) → box만 권고.
# 형제 노브는 기본 유지 권장(빈 값 대입 금지 — float 필드라 빈 문자열은 파싱 실패). 필요 시 주석 해제:
#LOCAL_OCR_TEXT_DET_THRESH=0.2
#LOCAL_OCR_TEXT_DET_UNCLIP_RATIO=2.5
LOCAL_OCR_TEXT_DET_BOX_THRESH=0.4
ENABLE_CLOVA_OCR=false
# Parser/domain correction remains fail-closed until reviewed artifacts and
# frozen-fixture reports pass team sign-off.
ENABLE_PARSER_DOMAIN_CORRECTION=false
PARSER_DOMAIN_CORRECTION_MODE=report_only
PARSER_DOMAIN_CORRECTION_ARTIFACT_PATH=data/nutrition_reference/domain_corrections/parser_domain_corrections.v1.json
# Cross-cutting release governance. Heavy artifact/benchmark checks run through
# scripts/evaluate_release_governance.py, not the request path.
GOVERNANCE_GATE_MODE=report_only
# Phase 4 / 게이트 #3: 학습 적재 파이프라인 + pgvector
ENABLE_IMAGE_LEARNING_PIPELINE=false
ENABLE_PGVECTOR_STORAGE=false
EMBEDDING_MODEL=clip-ViT-B-32
# 실제 모델 probe로 차원이 확인된 뒤에만 설정한다. 비워두면 runner 결과를 기록한다.
EMBEDDING_DIMENSIONS=
# 이미지 보유 기간(일). 0 = 분석 직후 즉시 삭제 (docs/17 §5).
IMAGE_RETENTION_DAYS=0
# 사용자 opt-in 이미지는 자동 필터와 operator 수동 검수 전에는 embedding job으로 넘기지 않는다.
ENABLE_LEARNING_AUTO_FILTER=true
REQUIRE_LEARNING_MANUAL_REVIEW=true
LEARNING_OBJECT_STORAGE_PROVIDER=disabled
# 기존 Supabase Storage를 쓸 때는 supabase_s3 + private bucket으로 설정한다.
LEARNING_OBJECT_STORAGE_BUCKET=
LEARNING_OBJECT_STORAGE_PREFIX=learning/images
# Hosted Supabase는 비워두면 SUPABASE_PROJECT_REF로
# https://<project_ref>.storage.supabase.co/storage/v1/s3 를 사용한다.
LEARNING_OBJECT_STORAGE_ENDPOINT_URL=
LEARNING_OBJECT_STORAGE_REGION=
# generic s3 전용. supabase_s3는 공식 호환성 표에서 SSE 헤더가 미지원이므로 전송하지 않는다.
LEARNING_OBJECT_STORAGE_SSE=AES256
LEARNING_OBJECT_STORAGE_LOCAL_PATH=.local/learning-images
