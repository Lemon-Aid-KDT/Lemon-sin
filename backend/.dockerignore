# Lemon Healthcare backend — Docker build context filter.
# Keep the build context small so multi-arch builds stay reproducible.

# Editor & OS noise
.DS_Store
.vscode/
.idea/

# Python caches and virtualenvs
__pycache__/
*.pyc
*.pyo
*.pyd
.venv/
venv/
*.egg-info/
.python-version

# Test + lint caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/

# Local secrets — must never enter the image
.env
.env.local
.env.*.local
.env.production
.env.development
api-key/

# Large fixtures and outputs
Nutrition-backend/tests/fixtures/
data/raw/
data/private/
data/processed/
outputs/
tmp/

# Documentation drafts (not needed in the runtime image)
Brand-New-update/

# Build artifacts
build/
dist/

# OS-specific
Thumbs.db
ehthumbs.db
