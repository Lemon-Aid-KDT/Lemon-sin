# -----------------------------------------------------------------------------
# Data & Models (LFS or external storage)
# -----------------------------------------------------------------------------
# Raw data
data/raw/*
!data/raw/kdris/
data/raw/kdris/*
!data/raw/kdris/2025/
!data/raw/kdris/2025/**
data/private/
backend/data/private/
data/processed/

# External OCR tool/source checkout. Keep out of repo history.
/PaddleOCR-main/
/PaddleOCR-main.zip
/sglang-main/
/sglang-main.zip

# Mascot binary asset bundles. Store originals out-of-repo; commit only tracked exports.
/assets/mascot/*.zip
/assets/mascot/Lemon-Aid_*/
/assets/mascot/lemonaid_*/

# Local development log artifacts
/firepit-log.txt

# Supplement label raw images and private workspaces. Only consent memos and
# directory placeholders are tracked; raw image bytes never enter the repo.
data/supplement_images/raw/friend_contributed/inbox/*
!data/supplement_images/raw/friend_contributed/inbox/CONSENT.md
!data/supplement_images/raw/friend_contributed/inbox/.gitkeep
data/supplement_images/raw/friend_contributed/ingested/images/*
!data/supplement_images/raw/friend_contributed/ingested/images/.gitkeep
data/supplement_images/raw/friend_contributed/ingested/metadata.jsonl
data/supplement_images/raw/web_crawl/*/images/*
!data/supplement_images/raw/web_crawl/*/images/.gitkeep
data/supplement_images/raw/web_crawl/*/metadata.jsonl
data/supplement_images/raw/public_sources/*.jpg
data/supplement_images/raw/public_sources/*.jpeg
data/supplement_images/raw/public_sources/*.png
data/supplement_images/raw/public_sources/*.webp
data/supplement_images/private_workspace/
data/supplement_images/interim/
data/supplement_images/processed/
data/supplement_images/quarantine/

# Local databases
*.db
*.sqlite
*.sqlite3

# Model weights / checkpoints
*.h5
*.hdf5
*.pth
*.ckpt
*.safetensors
models/checkpoints/

