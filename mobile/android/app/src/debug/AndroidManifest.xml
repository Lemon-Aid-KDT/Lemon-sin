<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- The INTERNET permission is required for development. Specifically,
         the Flutter tool needs it to communicate with the running application
         to allow setting breakpoints, to provide hot reload, etc.
    -->
    <uses-permission android:name="android.permission.INTERNET"/>

    <!-- Cleartext is NOT globally enabled in debug. The scoped
         debug/res/xml/network_security_config.xml permits cleartext ONLY for
         local dev hosts (10.0.2.2 / 127.0.0.1 / localhost); the application's
         networkSecurityConfig reference is inherited from the main manifest. -->
</manifest>
