<?xml version="1.0" encoding="utf-8"?>
<!--
  Debug-only network security config.
  Cleartext (HTTP) is permitted ONLY for local development backends reached from
  an emulator/simulator or loopback. Everything else must use HTTPS even in debug,
  so a debug APK handed to a tester cannot silently send token-bearing traffic
  over plaintext to an arbitrary host.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="false" />
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">10.0.2.2</domain>
        <domain includeSubdomains="false">127.0.0.1</domain>
        <domain includeSubdomains="false">localhost</domain>
    </domain-config>
</network-security-config>
