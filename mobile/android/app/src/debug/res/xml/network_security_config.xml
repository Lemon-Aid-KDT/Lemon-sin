<?xml version="1.0" encoding="utf-8"?>
<!-- Debug-build overlay: replaces the main network security config ONLY in
     debug builds (Android build-type resource merging). Release builds keep
     the fully cleartext-blocked config in src/main, which the
     release_security_config_test guards. -->
<network-security-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
    <!-- Local dev API only: Android emulator loopback aliases. -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">10.0.2.2</domain>
        <domain includeSubdomains="false">127.0.0.1</domain>
        <domain includeSubdomains="false">localhost</domain>
    </domain-config>
</network-security-config>
