# Lemon Aid mobile — 빌드 시 dart-define 으로 주입할 환경 변수 템플릿
#
# 이 파일은 어떤 키가 필요한지만 알려주는 문서입니다.
# 실제 키는 절대 이 파일에 적지 마세요. 깃에 올라가는 순간 영구 노출됩니다.
#
# 실 키는 별도로 받아 보관 (1Password / 카톡 1:1 등) 하고,
# 빌드할 때 dart-define 으로 주입합니다.
#
# 예시:
#   flutter run \
#     --dart-define=API_BASE_URL=http://10.0.2.2:8000 \
#     --dart-define=KAKAO_NATIVE_APP_KEY=xxxxxxxxxxxxxxxx \
#     --dart-define=GOOGLE_SERVER_CLIENT_ID=xxxxxxxx-xxxxx.apps.googleusercontent.com
#
# ────────────────────────────────────────────────

# 백엔드 API 베이스 URL
# - Android 에뮬레이터 기본: http://10.0.2.2:8000 (자동 감지)
# - 실기기: 호스트 PC IP 또는 배포 도메인
API_BASE_URL=

# 카카오 Native App Key — 카카오 디벨로퍼스 → 내 애플리케이션 → 앱 키
# 노출 시 즉시 회전 (재발급) 필요
KAKAO_NATIVE_APP_KEY=

# 구글 Web Client ID — Google Cloud Console → OAuth 2.0 클라이언트 ID (Web)
# 백엔드 google_client_id 와 동일한 값이어야 토큰 aud 검증 통과
GOOGLE_SERVER_CLIENT_ID=
